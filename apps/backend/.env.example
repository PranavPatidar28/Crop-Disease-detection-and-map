# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Database (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
JWT_SECRET=replace-me-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=crop-disease/reports

# FastAPI (ML inference service — to be wired in later)
FASTAPI_URL=http://localhost:8000

# AI provider: mock | fastapi
AI_PROVIDER=mock

# Outbreak engine (v7)
OUTBREAK_CREATE_THRESHOLD=5
OUTBREAK_CREATE_RADIUS_KM=3
OUTBREAK_ESCALATE_THRESHOLD=10
OUTBREAK_ESCALATE_RADIUS_KM=5
OUTBREAK_HIGH_REPORT_COUNT=20
OUTBREAK_HIGH_SEVERITY_COUNT=5
OUTBREAK_DEACTIVATE_HOURS=48

# Notifications (v8)
# Optional: set when you have an Expo push access token (raises rate limit)
EXPO_ACCESS_TOKEN=
NOTIFICATION_NEARBY_BUFFER_KM=5
NOTIFICATION_DEDUP_WINDOW_HOURS=24
NOTIFICATION_REPORT_TRIGGER_RADIUS_KM=5
PLOT_MAX_PER_USER=20

# Demo mode (v10) — speeds up mock AI, biases toward severe diseases.
# Set to false for real production deployments.
DEMO_MODE=true
GIT_SHA=
BUILD_TIME=
